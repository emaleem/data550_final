library(ggplot2)
library(dplyr)
library(tidyr)
#Clean up endemicity variable
data2 <- data |>
arrange(iuCode, year) |>
group_by(iuCode) |>
mutate(endemicity_filled = ifelse(endemicity == "Not reported",
NA, endemicity)) |>
fill(endemicity_filled, .direction = "down") |>
mutate(
mda_status_final = case_when(
endemicity_filled == "Non-endemic" ~ "Non-endemic",
endemicity_filled == "Endemic (under MDA)" ~ "MDA Started",
TRUE ~ "MDA Not Started")
) |>
mutate(mda_started_flag = ifelse(mda_status_final == "MDA Started", 1, 0)) |>
mutate(ever_started = cummax(mda_started_flag)) |>
mutate(mda_status_final = case_when(
endemicity_filled == "Non-endemic" ~ "Non-endemic",
ever_started == 1 ~ "MDA Started",
TRUE ~ "MDA Not Started"
)) |>
ungroup()
#Summary of IUs in South Sudan
table <- data2 |>
filter(year == 2024) |>
tbl_summary(include = mda_status_final)
table
#Create endemicity bar graph
data2 |>
filter(mda_status_final != "Non-endemic") |>
group_by(year, mda_status_final) |>
summarize(n_ius = n_distinct(iuCode), .groups = "drop") |>
ggplot(aes(x = n_ius, y = factor(year), fill = mda_status_final)) +
geom_col() +
scale_fill_manual(values = c("MDA Started" = "orange",
"MDA Not Started" = "red")) +
labs(title = "Number of IUs by MDA Status Each Year",
x = "Number of LF Endemic IUs",
y = "Year",
fill = "MDA Status") +
theme_minimal()
# Calculate cumulative population treated by year
treatment <- data2 |>
group_by(year) |>
summarize(
popTreat = sum(popTreat, na.rm = TRUE),
popTarget = sum(popTrg, na.rm = TRUE)
) |>
arrange(year)
# Create treatment line graph
ggplot(treatment, aes(x = year)) +
geom_line(aes(y = popTarget, color = "Target Population"), size = 1,) +
geom_point(aes(y = popTarget, color = "Target Population"), size = 2) +
geom_line(aes(y = popTreat, color = "Population Treated"), size = 1) +
geom_point(aes(y = popTreat, color = "Population Treated"), size = 2) +
scale_color_manual(values = c("Population Treated" = "navyblue",
"Target Population" = "lightsteelblue")) +
labs(title = "Lymphatic Filariasis: Population Treated vs Treatment Target by Year",
x = "Year",
y = "Population",
color = "") +
theme_minimal() +
scale_y_continuous(labels = scales::comma)
table <- data2 |>
filter(year == 2024) |>
tbl_summary(include = mda_status_final ~ "Endemicity")
